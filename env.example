# Copy to .env.local and fill in. For Vercel: set these in Project → Settings → Environment Variables.

# PostgreSQL (required). Use sslmode=require for Neon/Supabase/RDS.
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# NextAuth — generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# Public URL of this deployment (required in production for SIWE + cookies)
NEXTAUTH_URL=https://your-project.vercel.app

# Primus zkTLS (server-only — never use NEXT_PUBLIC_ for the secret)
PRIMUS_APP_ID=
PRIMUS_APP_SECRET=
# Optional: set to "development" for Primus dev endpoints (default: production)
# PRIMUS_ENV=development
